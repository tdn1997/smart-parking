 261          // Khởi tạo Timer cho Servo PWM (gọi 1 lần trong main())
 262          void Servo_Init(void)
 263          {
 264   1          TMOD = 0x11; // Timer0 và Timer1 mode 1 (16-bit)
 265   1      
 266   1          // Timer 0: Tạo chu kỳ 20ms (50Hz)
 267   1          TH0 = (65536 - 20000) >> 8; // Giá trị ban đầu cho 20ms
 268   1          TL0 = (65536 - 20000) & 0xFF;
 269   1      
 270   1          // Timer 1: Tạo pulse width (sẽ thay đổi động)
 271   1          TH1 = (65536 - 1500) >> 8; // Ban đầu 1.5ms
 272   1          TL1 = (65536 - 1500) & 0xFF;
 273   1      
 274   1          ET0 = 1; // Enable Timer 0 interrupt
 275   1          ET1 = 1; // Enable Timer 1 interrupt
 276   1          EA = 1;  // Enable global interrupt
 277   1      
 278   1          TR0 = 1; // Bật Timer 0
 279   1          TR1 = 0; // Timer 1 sẽ bật trong ISR
 280   1      }
 281          // Timer 0 Interrupt: Tạo chu kỳ 20ms
 282          void Timer0_ISR() interrupt 1
 283          {
 284   1          // Reload cho 20ms
 285   1          TH0 = (65536 - 20000) >> 8;
 286   1          TL0 = (65536 - 20000) & 0xFF;
 287   1      
 288   1          servo_state = 1; // Bắt đầu pulse ON
 289   1          SERVO_PIN = 1;
 290   1      
 291   1          // Load Timer 1 với pulse width hiện tại
 292   1          TH1 = (65536 - servo_pulse) >> 8;
 293   1          TL1 = (65536 - servo_pulse) & 0xFF;
 294   1      
 295   1          TR1 = 1; // Bật Timer 1
 296   1      }
 297          
 298          // Timer 1 Interrupt: Kết thúc pulse (tắt pin)
 299          void Timer1_ISR() interrupt 3
 300          {
 301   1          TR1 = 0; // Tắt Timer 1
 302   1          SERVO_PIN = 0;
 303   1          servo_state = 0;
